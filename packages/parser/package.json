{
  "name": "dcss-morgue-parser",
  "version": "0.5.2",
  "description": "Browser-safe Dungeon Crawl Stone Soup morgue parser that turns morgue text into structured JSON.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "llms.txt",
    "docs",
    "LICENSE.md"
  ],
  "sideEffects": false,
  "keywords": [
    "dcss",
    "dungeon crawl stone soup",
    "morgue",
    "parser",
    "typescript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit",
    "pack:dry": "npm pack --dry-run"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caiman-dorohedoro/dcss-morgue-parser.git",
    "directory": "packages/parser"
  },
  "homepage": "https://github.com/caiman-dorohedoro/dcss-morgue-parser#readme",
  "bugs": {
    "url": "https://github.com/caiman-dorohedoro/dcss-morgue-parser/issues"
  }
}
