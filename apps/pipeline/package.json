{
  "name": "@dcss-morgue/pipeline",
  "description": "Sampling and QA pipeline for collecting raw DCSS morgues and validating parser output.",
  "private": true,
  "type": "module",
  "scripts": {
    "parser:build": "npm run build -w dcss-morgue-parser",
    "pretest": "npm run parser:build",
    "test": "vitest run",
    "pretest:watch": "npm run parser:build",
    "test:watch": "vitest",
    "pretypecheck": "npm run parser:build",
    "typecheck": "tsc --noEmit",
    "prefixtures:meta": "npm run parser:build",
    "fixtures:meta": "tsx scripts/generateFixtureMetadata.ts",
    "crawl:equipment-catalog": "tsx scripts/generateCrawlEquipmentCatalog.ts",
    "prebackfill:parsed": "npm run parser:build",
    "backfill:parsed": "tsx scripts/backfillParsedData.ts",
    "prereview:compare": "npm run parser:build",
    "review:compare": "tsx scripts/compareReviewPair.ts",
    "prereview:fixtures": "npm run parser:build",
    "review:fixtures": "tsx scripts/exportFixtureReview.ts",
    "prebootstrap": "npm run parser:build",
    "bootstrap": "tsx src/cli.ts bootstrap",
    "preincremental": "npm run parser:build",
    "incremental": "tsx src/cli.ts incremental",
    "preaudit": "npm run parser:build",
    "audit": "tsx src/cli.ts audit"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "dcss-morgue-parser": "0.6.5",
    "p-queue": "^8.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.10"
  }
}
